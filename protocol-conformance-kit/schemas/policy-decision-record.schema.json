{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruleoak.com/schemas/policy-decision-record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "title": "RuleOak PolicyDecisionRecord",
  "required": [
    "schemaVersion",
    "recordType",
    "decisionId",
    "runId",
    "action",
    "subject",
    "effect",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ruleoak.governance.v1"
    },
    "recordType": {
      "const": "PolicyDecisionRecord"
    },
    "decisionId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "effect": {
      "enum": [
        "allow",
        "deny",
        "approval_required"
      ]
    },
    "decision": {
      "enum": [
        "allowed",
        "blocked",
        "approval_required"
      ]
    },
    "matchedRuleIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "metadata": {
      "type": "object"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordHash": {
      "type": "string"
    }
  }
}
