{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruleoak.com/schemas/audit-event.schema.json",
  "type": "object",
  "additionalProperties": false,
  "title": "RuleOak AuditEvent",
  "required": [
    "schemaVersion",
    "recordType",
    "eventId",
    "runId",
    "eventType",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ruleoak.governance.v1"
    },
    "recordType": {
      "const": "AuditEvent"
    },
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "eventType": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": [
        "string",
        "null"
      ]
    },
    "subject": {
      "type": [
        "string",
        "null"
      ]
    },
    "actor": {
      "type": [
        "string",
        "null"
      ]
    },
    "policyDecision": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidenceId": {
      "type": [
        "string",
        "null"
      ]
    },
    "approvalId": {
      "type": [
        "string",
        "null"
      ]
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "previousHash": {
      "type": [
        "string",
        "null"
      ]
    },
    "eventHash": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordHash": {
      "type": "string"
    }
  }
}
