{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruleoak.com/schemas/run-record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "title": "RuleOak RunRecord",
  "required": [
    "schemaVersion",
    "recordType",
    "runId",
    "domain",
    "workflow",
    "actor",
    "status",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ruleoak.governance.v1"
    },
    "recordType": {
      "const": "RunRecord"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "workflow": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "created",
        "running",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    },
    "recordHash": {
      "type": "string"
    }
  }
}
