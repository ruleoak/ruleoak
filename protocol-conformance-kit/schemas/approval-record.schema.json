{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruleoak.com/schemas/approval-record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "title": "RuleOak ApprovalRecord",
  "required": [
    "schemaVersion",
    "recordType",
    "approvalId",
    "runId",
    "action",
    "subject",
    "decision",
    "actor",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ruleoak.governance.v1"
    },
    "recordType": {
      "const": "ApprovalRecord"
    },
    "approvalId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "enum": [
        "approved",
        "rejected",
        "needs_review",
        "not_required",
        "pending"
      ]
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "metadata": {
      "type": "object"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordHash": {
      "type": "string"
    }
  }
}
