{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruleoak.com/schemas/evidence-bundle.schema.json",
  "title": "RuleOak EvidenceBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "bundleType",
    "bundleId",
    "runId",
    "generatedAt",
    "records",
    "recordHashes",
    "bundleHash"
  ],
  "properties": {
    "protocol": {
      "const": "ruleoak.governance.v1"
    },
    "bundleType": {
      "const": "RuleOakEvidenceBundle"
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "records": {
      "type": "array",
      "minItems": 1
    },
    "recordHashes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "recordType",
          "id",
          "hash"
        ],
        "additionalProperties": false,
        "properties": {
          "recordType": {
            "type": "string"
          },
          "id": {
            "type": [
              "string",
              "null"
            ]
          },
          "hash": {
            "type": "string"
          }
        }
      }
    },
    "redactionManifest": {
      "type": [
        "object",
        "null"
      ]
    },
    "metadata": {
      "type": "object"
    },
    "bundleHash": {
      "type": "string"
    }
  }
}
