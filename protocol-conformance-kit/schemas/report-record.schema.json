{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruleoak.com/schemas/report-record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "title": "RuleOak ReportRecord",
  "required": [
    "schemaVersion",
    "recordType",
    "reportId",
    "runId",
    "title",
    "summary",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ruleoak.governance.v1"
    },
    "recordType": {
      "const": "ReportRecord"
    },
    "reportId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object"
        }
      ]
    },
    "records": {
      "type": "array"
    },
    "metadata": {
      "type": "object"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordHash": {
      "type": "string"
    }
  }
}
