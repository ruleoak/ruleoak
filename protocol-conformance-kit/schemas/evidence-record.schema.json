{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruleoak.com/schemas/evidence-record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "title": "RuleOak EvidenceRecord",
  "required": [
    "schemaVersion",
    "recordType",
    "evidenceId",
    "runId",
    "action",
    "subject",
    "createdAt",
    "hash"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ruleoak.governance.v1"
    },
    "recordType": {
      "const": "EvidenceRecord"
    },
    "evidenceId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "subjectType": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "hash": {
      "type": "string",
      "minLength": 1
    },
    "redactionManifestId": {
      "type": "string"
    },
    "recordHash": {
      "type": "string"
    }
  }
}
