{
  "name": "ai-coding-agent-governance",
  "version": "1.0.0",
  "boundary": "local_first_coding_agent_tool_boundary",
  "allowedTools": [
    "read.task_brief",
    "read.workspace_policy",
    "read.repo_file",
    "read.git_status",
    "inspect.diff_plan",
    "scan.secrets",
    "run.test_suite",
    "read.review_policy",
    "generate.audit_report"
  ],
  "approvalRequired": [
    "write.source_file",
    "delete.workspace_file",
    "git.push_main",
    "install.dependency"
  ],
  "blockedTools": [
    "run.destructive_shell",
    "read.env_secret",
    "exfiltrate.repository",
    "bypass.git_review"
  ],
  "rules": [
    {
      "id": "coding.read.repo.allowed",
      "effect": "allow",
      "description": "Read-only workspace evidence collection is allowed."
    },
    {
      "id": "coding.write.source.needs_approval",
      "effect": "approval_required",
      "description": "Source edits require human approval and evidence."
    },
    {
      "id": "coding.shell.destructive.blocked",
      "effect": "deny",
      "description": "Destructive shell commands and secret exfiltration are blocked."
    }
  ],
  "requiredEvidence": [
    "task brief",
    "workspace policy",
    "git status",
    "diff plan",
    "secret scan",
    "test result",
    "review boundary"
  ]
}