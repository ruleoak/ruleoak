{
  "name": "personal-local-first-assistant-governance",
  "version": "1.0.0",
  "boundary": "local_first_personal_assistant_external_action_boundary",
  "allowedTools": [
    "read.user_intent",
    "read.local_note_index",
    "read.local_note",
    "read.calendar_summary",
    "draft.email",
    "scan.private_data",
    "read.external_action_policy",
    "generate.local_report"
  ],
  "approvalRequired": [
    "send.email",
    "create.calendar_event",
    "modify.local_file",
    "run.local_command"
  ],
  "blockedTools": [
    "upload.private_files",
    "delete.photo_library",
    "send.without_review",
    "expose.secrets"
  ],
  "rules": [
    {
      "id": "personal.local.read.allowed",
      "effect": "allow",
      "description": "Declared local reads and drafts are allowed locally."
    },
    {
      "id": "personal.external.send.needs_approval",
      "effect": "approval_required",
      "description": "External sends and writes require explicit approval."
    },
    {
      "id": "personal.private.upload.blocked",
      "effect": "deny",
      "description": "Private file upload and secret exposure are blocked."
    }
  ],
  "requiredEvidence": [
    "user intent",
    "local note index",
    "local note",
    "calendar summary",
    "draft",
    "privacy scan",
    "external action policy"
  ]
}