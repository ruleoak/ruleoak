{
  "name": "sre-monitoring-change-governance",
  "version": "1.0.0",
  "boundary": "local_first_approval_required_for_production_writes",
  "allowedTools": [
    "read.change_ticket",
    "read.metric_baseline",
    "read.alert_policy",
    "read.runbook",
    "read.pull_request",
    "generate.audit_report"
  ],
  "approvalRequired": [
    "write.monitoring_threshold",
    "merge.alert_rule_pr",
    "notify.production_change"
  ],
  "blockedTools": [
    "disable.production_alert",
    "delete.alert_policy",
    "write.monitoring_threshold_without_ticket",
    "bypass.approval"
  ],
  "rules": [
    {
      "id": "sre.monitoring.readonly.evidence.allowed",
      "effect": "allow",
      "description": "Read-only collection of ticket, metrics, runbook, and PR evidence is allowed locally."
    },
    {
      "id": "sre.monitoring.production.write.needs_approval",
      "effect": "approval_required",
      "description": "Production monitoring threshold writes require explicit approval and an evidence bundle."
    },
    {
      "id": "sre.monitoring.disable_alert.blocked",
      "effect": "deny",
      "description": "Disabling or deleting production alerts is blocked by default."
    }
  ],
  "requiredEvidence": [
    "change request",
    "ticket state",
    "metric baseline",
    "current alert policy",
    "runbook control",
    "pull request diff/checks",
    "RACI"
  ]
}
