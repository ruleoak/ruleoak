{
  "name": "ruleoak",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "ruleoak",
      "version": "0.1.0",
      "workspaces": [
        "packages/protocol",
        "packages/core",
        "packages/cli"
      ],
      "engines": {
        "node": ">=18"
      }
    },
    "node_modules/@ruleoak/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@ruleoak/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@ruleoak/protocol": {
      "resolved": "packages/protocol",
      "link": true
    },
    "packages/cli": {
      "name": "@ruleoak/cli",
      "version": "0.1.0",
      "license": "Apache-2.0",
      "dependencies": {
        "@ruleoak/core": "^0.1.0",
        "@ruleoak/protocol": "^0.1.0"
      },
      "bin": {
        "ruleoak": "bin/ruleoak.js"
      }
    },
    "packages/core": {
      "name": "@ruleoak/core",
      "version": "0.1.0",
      "license": "Apache-2.0",
      "dependencies": {
        "@ruleoak/protocol": "^0.1.0"
      }
    },
    "packages/protocol": {
      "name": "@ruleoak/protocol",
      "version": "0.1.0",
      "license": "MIT"
    }
  }
}
